{
  "name": "ai-delivery-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AI Delivery Engine orchestrates AI agents to transform project briefs into actionable delivery backlogs.",
  "type": "module",
  "scripts": {
    "backlog:export": "node --experimental-strip-types src/exportBacklog.ts",
    "backlog:review": "node --experimental-strip-types src/reviewBacklog.ts",
    "backlog:run": "node --experimental-strip-types src/index.ts",
    "demo:validate": "node --experimental-strip-types src/demoValidate.ts",
    "import:po": "node --experimental-strip-types src/importPo.ts",
    "project:status": "node --experimental-strip-types src/projectStatus.ts",
    "prompt:po": "node --experimental-strip-types src/promptPo.ts",
    "prompt:specialists": "node --experimental-strip-types src/promptSpecialists.ts",
    "prompt:specialist": "node --experimental-strip-types src/promptSpecialist.ts",
    "specialist:check": "node --experimental-strip-types src/specialistCheck.ts",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
